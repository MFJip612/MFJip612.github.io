{
	"name": "mfjip612-github-io",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "run-p type-check \"build-only {@}\" --",
		"build-only": "vite build && tsx scripts/render-html.ts",
		"preview": "pnpm run build && wrangler dev",
