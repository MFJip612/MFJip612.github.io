		"vue": "^3.5.39",
		"vue-router": "^5.1.0"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.42.3",
		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^24.13.2",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vue/tsconfig": "^0.9.1",
		"fast-glob": "^3.3.3",
		"naive-ui": "^2.44.1",
		"npm-run-all2": "^9.0.2",
		"tsx": "^4.22.4",
		"typescript": "~6.0.3",
